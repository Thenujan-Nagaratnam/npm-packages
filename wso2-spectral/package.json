{
  "name": "@wso2/wso2-spectral",
  "version": "1.0.0",
  "description": "Reusable Spectral validation result builder for API governance and AI readiness rulesets",
  "engines": {
    "node": ">=18"
  },
  "main": "index.js",
  "bin": {
    "wso2-spectral": "bin/wso2-spectral.js"
  },
  "scripts": {
    "check:node": "node ./scripts/check-node-version.js",
    "build": "node -e \"console.log('No build step required')\"",
    "lint": "node -e \"console.log('No lint configured')\"",
    "cli:help": "node ./bin/wso2-spectral.js --help",
    "test": "node ./test/run-tests.js",
    "prepack": "npm run check:node"
  },
  "files": [
    "bin",
    "src",
    "index.js",
    "utils",
    "rule-packs"
  ],
  "author": "WSO2",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "dependencies": {
    "@stoplight/spectral-core": "1.22.0",
    "@stoplight/spectral-formats": "1.8.2",
    "@stoplight/spectral-functions": "1.10.2",
    "@stoplight/spectral-parsers": "1.0.5",
    "@stoplight/spectral-rulesets": "1.22.1",
    "js-yaml": "4.1.1"
  }
}
