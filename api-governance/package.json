{
  "name": "@wso2/api-governance",
  "version": "1.0.0",
  "description": "API governance and quality reporting tool — lint OpenAPI specs against OWASP, REST, and AI Readiness rulesets",
  "engines": {
    "node": ">=18"
  },
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "bin": {
    "api-governance": "bin/api-governance.js"
  },
  "scripts": {
    "check:node": "node ./scripts/check-node-version.js",
    "build": "node -e \"console.log('No build step required')\"",
    "lint": "node -e \"console.log('No lint configured')\"",
    "cli:help": "node ./bin/api-governance.js --help",
    "test": "node ./test/run-tests.js",
    "prepack": "npm run check:node"
  },
  "files": [
    "bin",
    "src",
    "index.js",
    "utils",
    "rule-packs"
  ],
  "author": "WSO2",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "dependencies": {
    "@stoplight/spectral-core": "1.22.0",
    "@stoplight/spectral-formats": "1.8.2",
    "@stoplight/spectral-functions": "1.10.2",
    "@stoplight/spectral-parsers": "1.0.5",
    "@stoplight/spectral-rulesets": "1.22.1",
    "js-yaml": "4.1.1"
  }
}
